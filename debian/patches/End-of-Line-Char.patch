+    def show3dB( self, freq ):
+        label = "-3 dB at f = %.3g"%freq
+        text = Qwt.QwtText( label )
+        text.setFont( QFont( "Helvetica", 10, QFont.Bold ) )
+        text.setColor( Qt.green )
+        self.d_marker1.setValue( freq, 0.0 )
+        self.d_marker1.setLabel( text )
