+def logSpace(size, xmin, xmax ):
+    array = []#np.zeros(0,float)
+    for i in range(size):
+        array.append(0.0)
+    if ( ( xmin <= 0.0 ) or ( xmax <= 0.0 ) or ( size <= 0 ) ):
+        return array;
+    imax = size - 1;
+    array[0] = xmin;
+    array[imax] = xmax;
+    lxmin = math.log( xmin )
+    lxmax = math.log( xmax )
+    lstep = ( lxmax - lxmin ) / imax 
+    for i in range(imax):
+        array[i] = math.exp( lxmin + i * lstep )
+    return array
