+symbol = Qwt.QwtSymbol( Qwt.QwtSymbol.Ellipse, QBrush( Qt.yellow ), QPen( Qt.red, 2 ), QSize( 8, 8 ) );
+curve.setSymbol( symbol )
+
+#x=np.arange(0,10,0.1)
+x = []
+y = []
+for i in range(101):
+    x.append(0.1*i)
+    y.append(math.sin(0.1*i))
+#y=np.sin(x)
+curve.setSamples(x,y)
+curve.attach(plot)
+
+plot.resize(600,400)
+plot.replot()
+plot.show()
