+
+    void setStyle( Style );
+    Style style() const;
+
+    void setPath( const QPainterPath & );
+    const QPainterPath &path() const;
+
+    void setPixmap( const QPixmap & );
+    const QPixmap &pixmap() const;
+
+    //void setGraphic( const QwtGraphic & );
