+    {
+        /*!
+          Return the value from the matrix, that is nearest to the
+          the requested position.
+         */
+        NearestNeighbour,
+
+        /*!
+          Interpolate the value from the distances and values of the
+          4 surrounding values in the matrix,
+         */
+        BilinearInterpolation
+    };
+
